rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Catch-All (Default Deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Core Primitives ---
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    // --- Validation Helpers ---

    function isValidUserConfig(data, isCreate) {
      return (!isCreate || data.keys().hasAll(['name', 'theme', 'soundEnabled', 'createdAt']))
        && (data.get('name', '') is string)
        && (data.get('theme', '') is string)
        && (data.get('soundEnabled', true) is bool)
        && (data.get('birthDate', null) == null || data.birthDate is string)
        && (data.get('currentActivity', null) == null || data.currentActivity is string)
        && (data.get('relationshipStatus', null) == null || data.relationshipStatus is string);
    }

    function isValidReading(data, isCreate) {
      return true;
    }

    function isValidEncyclopediaEntry(data, isCreate) {
      return data.keys().hasOnly(['interpretation', 'createdAt'])
        && data.interpretation is string && data.interpretation.size() <= 15000
        && (isCreate ? data.createdAt == request.time : true);
    }

    // --- Match Rules ---

    match /users/{userId} {
      allow read, write: if true;
      
      match /readings/{readingId} {
        allow read, write: if true;
      }
    }

    match /encyclopedia_cache/{cardId} {
      allow read: if true;
      allow create: if isSignedIn()
                    && isValidId(cardId)
                    && isValidEncyclopediaEntry(incoming(), true);
      allow update: if false;
      allow delete: if false;
    }
  }
}
